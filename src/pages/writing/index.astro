---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Navigation } from '@/components/layout/Navigation';
import { Footer } from '@/components/layout/Footer';
import { getCollection } from 'astro:content';
import { getPublishedWriting, groupBySeries, formatDateShort } from '@/lib/content';

const allWriting = await getPublishedWriting();
const allSeries = await getCollection('series');
const { seriesMap } = groupBySeries(allWriting);
const activeSeries = allSeries.filter(s => (seriesMap.get(s.slug)?.length ?? 0) > 0);
---

<BaseLayout title="Writing">
  <Navigation client:idle />

  <main class="w-full max-w-3xl mx-auto px-6 pt-48 pb-24">
    <header class="mb-20">
      <p class="text-[10px] uppercase tracking-[0.25em] text-[#555555] mb-4">Writing</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tighter text-white mb-4">Writing & Logs</h1>
      <p class="text-[#86868B] font-light text-base max-w-lg">Essays, field notes, and personal logs — a quieter voice behind the work.</p>
    </header>
    
    <!-- ── Series ── -->
    {activeSeries.length > 0 && (
      <section class="mb-24">
        <h2 class="text-[10px] uppercase tracking-[0.25em] text-[#555555] mb-8">Series</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {activeSeries.map(series => {
            const count = seriesMap.get(series.slug)?.length || 0;
            return (
              <a href={`/series/${series.slug}`} class="group block p-6 bg-white/[0.02] border border-white/[0.05] rounded-xl hover:bg-white/[0.04] hover:border-white/[0.1] transition-all duration-300">
                <h3 class="text-base font-medium text-[#F5F5F7] group-hover:text-white transition-colors tracking-tight mb-2">{series.data.title}</h3>
                <p class="text-sm text-[#86868B] font-light leading-relaxed mb-3 line-clamp-2">{series.data.description}</p>
                <span class="text-[10px] uppercase tracking-widest text-[#555555]">{count} {count === 1 ? 'entry' : 'entries'}</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- ── All Articles ── -->
    <section>
      <h2 class="text-[10px] uppercase tracking-[0.25em] text-[#555555] mb-8">All Articles</h2>
      <div class="flex flex-col">
        {allWriting.map((post) => (
          <a href={`/writing/${post.slug}`} class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 py-6 border-b border-white/[0.04] hover:border-white/[0.1] transition-colors">
            <time class="text-xs text-[#555555] tracking-wide flex-shrink-0 sm:w-28 tabular-nums">
              {formatDateShort(post.data.publishDate)}
            </time>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-medium text-[#E5E5EA] group-hover:text-white transition-colors tracking-tight mb-1">{post.data.title}</h3>
              {post.data.excerpt && (
                <p class="text-sm text-[#86868B] font-light leading-relaxed truncate">{post.data.excerpt}</p>
              )}
            </div>
            {post.data.seriesId && (
              <span class="text-[10px] uppercase tracking-widest text-[#555555] flex-shrink-0">{post.data.seriesId}</span>
            )}
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
