---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Navigation } from '@/components/layout/Navigation';
import { CustomCursor } from '@/components/ui/CustomCursor';
import { NoiseOverlay } from '@/components/ui/NoiseOverlay';

import { LiquidStatement } from '@/components/sections/LiquidStatement';
import { HomepageShowreel, HOMEPAGE_SHOWREEL_POSTER_SRC } from '@/components/sections/HomepageShowreel';
import { HonorsHero } from '@/components/sections/HonorsHero';
import { AchievementTimeline } from '@/components/sections/AchievementTimeline';
import { FulbrightGalaxy } from '@/components/sections/FulbrightGalaxy';
---

<BaseLayout>
  <link slot="head" rel="preload" as="image" href={HOMEPAGE_SHOWREEL_POSTER_SRC} />
  <CustomCursor client:media="(pointer: fine) and (hover: hover) and (min-width: 1024px)" />
  <NoiseOverlay />
  <Navigation client:idle />

  <main>
    <HomepageShowreel />

    <LiquidStatement client:visible />

    <HonorsHero client:visible />

    <AchievementTimeline client:visible />

    <FulbrightGalaxy client:visible />

  </main>

  <script>
    const showreelVideo = document.querySelector<HTMLVideoElement>('[data-homepage-showreel-video]');

    if (showreelVideo) {
      let isVisible = true;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const syncPlayback = () => {
        if (document.hidden || !isVisible || prefersReducedMotion.matches) {
          showreelVideo.pause();
          return;
        }

        void showreelVideo.play().catch(() => {});
      };

      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          ([entry]) => {
            isVisible = Boolean(entry?.isIntersecting) && (entry?.intersectionRatio ?? 0) > 0.12;
            syncPlayback();
          },
          { threshold: [0, 0.12, 0.5], rootMargin: '96px 0px' },
        );

        observer.observe(showreelVideo);
      }

      document.addEventListener('visibilitychange', syncPlayback);
      window.addEventListener('pagehide', () => showreelVideo.pause(), { once: true });
      syncPlayback();
    }
  </script>
</BaseLayout>
