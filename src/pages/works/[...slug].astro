---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Navigation } from '@/components/layout/Navigation';
import { Footer } from '@/components/layout/Footer';
import { CinematicWorkHero } from '@/components/sections/CinematicWorkHero';
import { MeltingTimeWorkExperience } from '@/components/sections/MeltingTimeWorkExperience';

export async function getStaticPaths() {
  const workEntries = await getCollection('works');
  return workEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const isMeltingTime = entry.id === 'the-melting-time';
const renderedEntry = isMeltingTime ? null : await render(entry);
const Content = renderedEntry?.Content;
---

<BaseLayout title={entry.data.title} description={entry.data.description} ogImage={entry.data.ogImage ?? entry.data.coverImage} ogType="article">
  {isMeltingTime && (
    <link
      slot="head"
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@600;900&display=swap"
    />
  )}
  <Navigation client:idle />

  {isMeltingTime ? (
    <MeltingTimeWorkExperience client:load />
  ) : (
    <>
      {/* Cinematic Hero Section */}
      {entry.data.coverImage && (
        <CinematicWorkHero 
          client:load 
          title={entry.data.title} 
          imageSrc={entry.data.coverImage} 
          videoSrc={entry.data.videoSrc}
          videoPoster={entry.data.videoPoster}
        />
      )}

      <main class="w-full max-w-6xl mx-auto px-4 min-[394px]:max-[430px]:px-5 min-[768px]:max-[1024px]:px-8 md:px-6 pt-12 min-[394px]:max-[430px]:pt-16 min-[768px]:max-[1024px]:pt-20 lg:pt-24 pb-20 min-[768px]:max-[1024px]:pb-24 relative z-20 bg-[#050505]">
        <!-- ── Title Block ── -->
        <div class="mb-20 min-[768px]:max-[1024px]:mb-24 lg:mb-32 mt-6 min-[768px]:max-[1024px]:mt-10 lg:mt-12 border-t border-white/[0.05] pt-10 min-[394px]:max-[430px]:pt-12 min-[768px]:max-[1024px]:pt-14 lg:pt-16">
          <div class="flex flex-col min-[768px]:max-[1024px]:flex-row md:flex-row gap-10 min-[768px]:max-[1024px]:gap-12 md:gap-16">
            <div class="w-full md:w-2/3">
              {entry.data.award && (
                <div class="text-[10px] uppercase tracking-[0.25em] text-[#FFD60A] mb-6 flex items-center gap-2">
                  <span class="inline-block w-2 h-2 rounded-full bg-[#FFD60A]"></span>
                  {entry.data.award}
                </div>
              )}
              <h1 class="text-[2.15rem] min-[394px]:max-[430px]:text-[2.5rem] min-[768px]:max-[1024px]:text-[3.4rem] md:text-6xl font-bold tracking-tighter text-white mb-3 leading-[1.02]">{entry.data.title}</h1>
              <p class="text-[15px] min-[394px]:max-[430px]:text-base min-[768px]:max-[1024px]:text-lg text-[#86868B] font-light tracking-tight mb-8 md:mb-10">A film about memory, place, and disappearance.</p>
              <p class="text-[15px] min-[768px]:max-[1024px]:text-base text-[#A1A1AA] font-light leading-[1.85] max-w-xl">{entry.data.description}</p>
            </div>
            
            <div class="w-full md:w-1/3 flex flex-col gap-4">
              {entry.data.role && (
                <div class="border border-white/[0.05] bg-white/[0.02] rounded-xl p-5 min-[768px]:max-[1024px]:p-6">
                  <h4 class="text-[10px] uppercase tracking-[0.25em] text-[#555555] mb-2">Role</h4>
                  <p class="text-sm text-[#E5E5EA] font-medium">{entry.data.role}</p>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- ── Editorial Content ── -->
        {Content && (
          <article class="w-full max-w-[42rem] min-[768px]:max-[1024px]:max-w-[44rem] mx-auto prose prose-sm sm:prose-base prose-invert prose-p:text-[#A1A1AA] prose-p:text-[15px] prose-p:leading-[1.85] prose-p:font-light prose-headings:text-white prose-headings:font-medium prose-headings:tracking-tight prose-h2:text-[10px] prose-h2:uppercase prose-h2:tracking-[0.25em] prose-h2:text-[#555555] prose-h2:font-normal prose-h2:mb-6 prose-h2:mt-20 md:prose-h2:mt-24 prose-strong:text-white prose-strong:font-medium prose-blockquote:border-white/[0.1] prose-blockquote:text-[#86868B] prose-ul:text-[#A1A1AA] prose-li:marker:text-[#666771]">
            <Content />
          </article>
        )}
      </main>
    </>
  )}

  {!isMeltingTime && <Footer />}
</BaseLayout>
