---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Navigation } from '@/components/layout/Navigation';
import { Footer } from '@/components/layout/Footer';
import { MyStoryMagicList } from '@/components/sections/MyStoryMagicList';
import { getSeriesPosts, toStoryFeedItems, formatDateShort, getDayLabel } from '@/lib/content';

export async function getStaticPaths() {
  const seriesEntries = await getCollection('series');
  return seriesEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const isMyStorySeries = entry.slug === 'my-story';
const order = isMyStorySeries ? 'newest' : 'oldest';
const backHref = isMyStorySeries ? '/' : '/writing';
const backLabel = isMyStorySeries ? '← Home / My Story' : '← Writing';

const seriesPosts = await getSeriesPosts(entry.slug, order);
const mainClass = isMyStorySeries
  ? 'w-full max-w-5xl mx-auto px-5 md:px-6 pt-32 md:pt-40 pb-20 md:pb-24'
  : 'w-full max-w-3xl mx-auto px-6 pt-48 pb-24';
const myStorySeriesItems = toStoryFeedItems(seriesPosts, formatDateShort);
---

<BaseLayout title={entry.data.title} description={entry.data.description} ogImage={entry.data.ogImage ?? entry.data.coverImage}>
  <Navigation client:idle />

  <main class={mainClass}>
    <!-- ── Series Header ── -->
    <header class="mb-20 border-b border-white/[0.05] pb-16">
      <a href={backHref} class="text-[10px] uppercase tracking-[0.25em] text-[#555555] mb-6 block hover:text-white transition-colors">{backLabel}</a>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tighter text-white mb-4">{entry.data.title}</h1>
      <p class="text-lg text-[#A1A1AA] font-light leading-relaxed max-w-2xl mb-8">{entry.data.description}</p>
      
      {entry.data.theme_tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {entry.data.theme_tags.map((tag: string) => (
            <span class="text-[10px] uppercase tracking-widest text-[#555555] border border-white/[0.06] rounded-full px-3 py-1">{tag}</span>
          ))}
        </div>
      )}
      
      <div class="mt-8 text-[#86868B] font-light text-sm leading-relaxed">
        <Content />
      </div>
    </header>

    <!-- ── Entries ── -->
    <section>
      <h3 class="text-[10px] uppercase tracking-[0.25em] text-[#555555] mb-8">Entries · {seriesPosts.length}</h3>
      {seriesPosts.length > 0 ? (
        isMyStorySeries ? (
          <MyStoryMagicList client:visible items={myStorySeriesItems} variant="series" />
        ) : (
          <div class="flex flex-col">
            {seriesPosts.map((post, i) => (
              <a href={`/writing/${post.slug}`} class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 py-5 border-b border-white/[0.04] hover:border-white/[0.1] transition-colors">
                <span class="text-xs text-[#555555] tracking-wide flex-shrink-0 sm:w-16 tabular-nums font-medium">
                  {isMyStorySeries ? getDayLabel(post.data.title) : String(i + 1).padStart(2, '0')}
                </span>
                <time class="text-xs text-[#555555] tracking-wide flex-shrink-0 sm:w-28 tabular-nums">
                  {formatDateShort(post.data.publishDate)}
                </time>
                <div class="flex-1 min-w-0">
                  <h4 class="text-base font-medium text-[#E5E5EA] group-hover:text-white transition-colors tracking-tight">{post.data.title}</h4>
                  {post.data.excerpt && (
                    <p class="text-sm text-[#86868B] font-light mt-1 truncate">{post.data.excerpt}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        )
      ) : (
          <p class="text-[#555555] font-light text-sm">No entries yet.</p>
        )}
    </section>
  </main>

  <Footer />
</BaseLayout>
