---
/**
 * Centralised <head> metadata for every page.
 * Drop this into BaseLayout so individual pages only pass simple props.
 */

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Fully-qualified canonical URL (optional). */
  canonical?: string;
  /** 'article' | 'website' — defaults to 'website'. */
  ogType?: 'article' | 'website';
  publishDate?: Date;
  updatedDate?: Date;
}

const SITE_NAME = '曾品翰 | Pin-Han Tseng';
const DEFAULT_DESCRIPTION = 'Engineering discipline meets visual storytelling.';
const DEFAULT_OG = '/og-default.png';

const isHttpUrl = (value: string) => {
  try {
    const url = new URL(value);
    return url.protocol === 'http:' || url.protocol === 'https:';
  } catch {
    return false;
  }
};

const toAbsoluteSiteUrl = (value: string | undefined) => {
  if (!value) return undefined;

  if (isHttpUrl(value)) {
    return value;
  }

  if (value.startsWith('/') && !value.startsWith('//') && Astro.site) {
    return new URL(value, Astro.site).href;
  }

  return undefined;
};

const {
  title,
  description = DEFAULT_DESCRIPTION,
  ogImage,
  canonical,
  ogType = 'website',
  publishDate,
  updatedDate,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;

// Resolve canonical: explicit prop > auto from current URL.
const resolvedCanonical = toAbsoluteSiteUrl(canonical) ?? (Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined);

// Resolve OG image to absolute URL for social platforms
const rawOg = ogImage ?? DEFAULT_OG;
const resolvedOg = toAbsoluteSiteUrl(rawOg) ?? (Astro.site ? new URL(DEFAULT_OG, Astro.site).href : DEFAULT_OG);
---

<!-- Primary -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<meta name="theme-color" content="#050505" />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<title>{pageTitle}</title>

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOg} />
<meta property="og:site_name" content={SITE_NAME} />
{resolvedCanonical && <link rel="canonical" href={resolvedCanonical} />}
{resolvedCanonical && <meta property="og:url" content={resolvedCanonical} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOg} />

<!-- Dates (articles) -->
{publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Fonts & Preconnects -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
<link rel="preconnect" href="https://res.cloudinary.com" crossorigin="anonymous" />
<link rel="dns-prefetch" href="//res.cloudinary.com" />
<link href="https://fonts.googleapis.com/css2?family=Anton&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
