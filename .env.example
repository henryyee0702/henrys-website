# Server-only values for the encrypted Umbra archive.
UMBRA_PASSWORD=
UMBRA_SESSION_SECRET=
UMBRA_ARCHIVE_KEY=

# Required on Preview/Production. Use the Upstash Redis Standard REST token (write access).
# Without a complete durable configuration, deployed Umbra unlock requests fail closed with 503.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy Vercel KV aliases are also supported instead of the UPSTASH_* pair:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
